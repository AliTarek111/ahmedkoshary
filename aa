<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>احمد كشري | Ahmed Koshary</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" type="image/png" sizes="16x16" href="C:\Users\A\Desktop\New folder\favicon-16x16.png">
  
    <style>
        :root {
            --gold: #d4af37;
            --dark-gold: #aa8928;
            --black: #0f0f0f;
            --soft-black: #1a1a1a;
            --white: #ffffff;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--black);
            color: var(--white);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .container {
            width: 100%;
            max-width: 450px;
            padding: 40px 20px;
            text-align: center;
        }

        /* صورة البروفايل */
        .profile-img {
            width: 110px;
            height: 110px;
            border-radius: 50%;
            border: 3px solid var(--gold);
            padding: 5px;
            margin-bottom: 20px;
            box-shadow: 0 0 20px rgba(212, 175, 55, 0.3);
        }

        h1 {
            font-size: 24px;
            margin-bottom: 10px;
            color: var(--gold);
            letter-spacing: 1px;
        }

        p {
            font-size: 16px;
            color: #ccc;
            margin-bottom: 30px;
        }

        /* الروابط الأساسية */
        .links-container {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .link-card {
            background: var(--soft-black);
            border: 1px solid var(--gold);
            color: var(--gold);
            padding: 15px;
            text-decoration: none;
            border-radius: 12px;
            font-weight: bold;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .link-card:hover {
            background: var(--gold);
            color: var(--black);
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(212, 175, 55, 0.4);
        }

        /* أيقونات التواصل الاجتماعي */
        .social-icons {
            margin-top: 40px;
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        .social-icons a {
            color: var(--white);
            font-size: 24px;
            transition: color 0.3s;
        }

        .social-icons a:hover {
            color: var(--gold);
        }

        /* تأثير ذهبي للنص */
        .golden-text {
            background: linear-gradient(to right, #bf953f, #fcf6ba, #b38728, #fbf5b7, #aa8e2c);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>
<body>

<div class="container">
    <img src="C:\Users\A\Desktop\unnamed - Copy.jpg" alt="Profile" class="profile-img">

    <h1 class="golden-text"> احمد كشري | Ahmed Koshary</h1>
    <p>✨ســوفـــت ويـــر✨</p>

    <div class="links-container">
        <a href="#" class="link-card">
            <i class="fas fa-shopping-bag"></i> مشاهدة جميع المنتجات
        </a>
        <a href="#" class="link-card">
            <i class="fas fa-envelope"></i> تواصل معي مباشرة
        </a>
        <a href="#" class="link-card">
            <i class="fas fa-paper-plane"></i> اشترك في النشرة البريدية
        </a>
        <a href="#" class="link-card">
            <i class="fas fa-globe"></i> موقعي الرسمي
        </a>
    </div>

    <div class="social-icons">
        <a href="#"><i class="fab fa-instagram"></i></a>
        <a href="#"><i class="fab fa-twitter"></i></a>
        <a href="#"><i class="fab fa-facebook"></i></a>
        <a href="#"><i class="fab fa-linkedin"></i></a>
        <a href="#"><i class="fab fa-tiktok"></i></a>
        <a href="#"><i class="fab fa-whatsapp"></i></a>
    </div>
</div>

</body>
</html>
